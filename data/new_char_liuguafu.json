{
  "id": "yuan-widow-01",
  "name": "\u5218\u5be1\u5987",
  "era": "\u5143\u00b7\u81f3\u6b63\u5e74\u95f4\uff08\u7ea61350\u5e74\uff09",
  "location": "\u5927\u90fd\uff08\u5317\u4eac\uff09",
  "oneLiner": "\u56db\u7b49\u4eba\u91cc\u7b2c\u4e09\u7b49\u7684\u6c49\u65cf\u5be1\u5987\uff0c\u9760\u4e00\u9505\u7f8a\u6c64\u6491\u8d77\u4e86\u4e09\u4e2a\u5b69\u5b50\u7684\u547d\u3002",
  "rarity": "common",
  "tone": "ember",
  "tags": ["\u5143\u4ee3", "\u5973\u6027", "\u5e95\u5c42", "\u996e\u98df", "\u5317\u4eac"],
  "events": [
    {
      "age": 0,
      "text": "\u4f60\u51fa\u751f\u5728\u5927\u90fd\u57ce\u5357\u7684\u6c49\u4eba\u805a\u5c45\u533a\u3002\u7236\u4eb2\u662f\u6ce5\u74e6\u5320\uff0c\u7ed9\u8499\u53e4\u8d35\u4eba\u4fee\u9662\u5b50\u3002\u5143\u671d\u628a\u4eba\u5206\u56db\u7b49\u2014\u2014\u8499\u53e4\u4eba\u3001\u8272\u76ee\u4eba\u3001\u6c49\u4eba\u3001\u5357\u4eba\u3002\u4f60\u5bb6\u7b2c\u4e09\u7b49\u3002\u8fd9\u610f\u5473\u7740\uff1a\u544a\u8499\u53e4\u4eba\u7684\u5b98\u53f8\u6c38\u8fdc\u8d62\u4e0d\u4e86\uff0c\u4f60\u7236\u4eb2\u88ab\u5f81\u53bb\u4fee\u57ce\u5899\u4e0d\u7ed9\u94b1\uff0c\u4f60\u54e5\u54e5\u6ca1\u8d44\u683c\u8003\u79d1\u4e3e\u3002\u4f46\u65e5\u5b50\u7167\u8fc7\u3002\u997f\u4e0d\u6b7b\u5c31\u884c\u3002",
      "choices": null
    },
    {
      "age": 15,
      "text": "\u4f60\u5ac1\u4e86\u4e2a\u5356\u7f8a\u6742\u7684\uff0c\u59d3\u8d75\uff0c\u6bd4\u4f60\u5927\u516b\u5c81\u3002\u4ed6\u4e0d\u6253\u4f60\uff0c\u631a\u7684\u94b1\u4ea4\u4f60\u7ba1\u3002\u4f60\u5b66\u4e86\u4ed6\u90a3\u9505\u7f8a\u6742\u6c64\uff1a\u7f8a\u809a\u3001\u7f8a\u80ba\u3001\u7f8a\u80a0\uff0c\u6d17\u4e03\u904d\u53bb\u81bb\u5473\uff0c\u7186\u56db\u4e2a\u65f6\u8fb0\u3002\u8499\u53e4\u4eba\u548c\u8272\u76ee\u4eba\u597d\u8fd9\u53e3\uff0c\u7ed9\u94b1\u75db\u5feb\u3002",
      "choices": null
    },
    {
      "age": 23,
      "text": "\u4e08\u592b\u6b7b\u4e86\u3002\u51ac\u5929\u4e70\u7f8a\u56de\u6765\u8def\u4e0a\u7ffb\u8f66\uff0c\u538b\u65ad\u4e86\u817f\uff0c\u4f24\u53e3\u70c2\u4e86\u3002\u7186\u4e86\u534a\u4e2a\u6708\u8d70\u7684\u3002\u4e09\u4e2a\u5b69\u5b50\uff1a\u5927\u7684\u4e03\u5c81\uff0c\u5c0f\u7684\u8fd8\u5728\u5403\u5976\u3002\u4f60\u6ca1\u54ed\u592a\u4e45\u2014\u2014\u7b2c\u4e09\u5929\u9505\u5c31\u7a7a\u4e86\u3002\u4f60\u63a5\u8fc7\u94fa\u5b50\u629b\u5934\u9732\u9762\uff0c\u90bb\u5c45\u8bf4\u95f2\u8bdd\u3002\u4f60\u6ca1\u7a7a\u7406\u3002\u4e09\u5f20\u5634\u7b49\u7740\u4f60\u3002",
      "choices": null
    },
    {
      "age": 26,
      "text": "\u94fa\u5b50\u6d3b\u4e0b\u6765\u4e86\u3002\u4f60\u536f\u65f6\u62a2\u8089\u5e02\u6700\u65b0\u9c9c\u7684\u4e0b\u6c34\uff0c\u56de\u6765\u6d17\u6ce1\u5207\u7096\uff0c\u6848\u677f\u4e00\u5929\u5237\u4e09\u904d\u3002\u4e00\u4e2a\u8272\u76ee\u5546\u4eba\u6210\u4e86\u5e38\u5ba2\uff1a\u300c\u4f60\u8fd9\u6c64\u6bd4\u56de\u56de\u5df7\u7684\u8fd8\u6b63\u3002\u300d\u8499\u53e4\u4eba\u672c\u6765\u5acc\u6c49\u4eba\u94fa\u5b50\u810f\u2014\u2014\u4f46\u4f60\u8fd9\u513f\u4ed6\u6311\u4e0d\u51fa\u6bdb\u75c5\u3002",
      "choices": [
        {
          "text": "\u4e13\u653b\u8272\u76ee\u4eba\u548c\u8499\u53e4\u4eba\u7684\u751f\u610f",
          "outcome": "\u4f60\u5728\u95e8\u53e3\u6302\u4e86\u5757\u6ce2\u65af\u82b1\u7eb9\u5e03\u5e18\u3002\u6c49\u4eba\u90bb\u5c45\u9a82\u4f60\u8c04\u5a9a\u3002\u4f46\u8272\u76ee\u5ba2\u4eba\u7ed9\u94b1\u591a\u3001\u8fd8\u4ecb\u7ecd\u670b\u53cb\u6765\u3002\u4f60\u4e0d\u5728\u4e4e\u2014\u2014\u8c01\u7ed9\u94b1\u4f60\u4f3a\u5019\u8c01\u3002",
          "branch": "main"
        },
        {
          "text": "\u8c01\u6765\u505a\u8c01\u7684\uff0c\u4e0d\u6311",
          "outcome": "\u8499\u53e4\u4eba\u6765\u591a\u653e\u8fa3\uff0c\u6c49\u4eba\u6765\u591a\u653e\u918b\uff0c\u8272\u76ee\u4eba\u628a\u732a\u8089\u9505\u548c\u7f8a\u8089\u9505\u5206\u5f00\u3002\u7d2f\u662f\u7d2f\u70b9\uff0c\u4f46\u8c01\u7684\u94b1\u90fd\u8d5a\u3002",
          "branch": "main"
        }
      ]
    },
    {
      "age": 35,
      "text": "\u81f3\u6b63\u5341\u5e74\u3002\u5929\u4e0b\u5f00\u59cb\u4e71\u4e86\u2014\u2014\u9ec4\u6cb3\u6539\u9053\u3001\u7ec7\u75ab\u3001\u7ea2\u5dfe\u519b\u3002\u5927\u90fd\u8fd8\u7b97\u592a\u5e73\u4f46\u7269\u4ef7\u6da8\u4e86\u56db\u500d\u3002\u8272\u76ee\u5e38\u5ba2\u5f80\u5357\u8dd1\u4e86\uff0c\u8499\u53e4\u8d35\u4eba\u5f00\u59cb\u6b20\u8d26\u3002\u4f60\u628a\u7f8a\u6742\u6c64\u6539\u6210\u534a\u7f8a\u6742\u534a\u841d\u535c\uff0c\u53c8\u52a0\u4e86\u9992\u5934\u548c\u8c46\u9762\u997c\u3002\u4e71\u4e16\u4eba\u4e0d\u6311\u5634\uff0c\u5403\u9971\u5c31\u884c\u3002",
      "choices": [
        {
          "text": "\u6491\u7740\u4e0d\u6da8\u4ef7",
          "outcome": "\u4f60\u628a\u91cf\u7f29\u4e86\u4e00\u70b9\u4f46\u4ef7\u94b1\u6ca1\u53d8\u3002\u8857\u574a\u5ff5\u4f60\u597d\u3002\u6709\u65f6\u4ed6\u4eec\u624b\u5934\u7d27\u4f60\u5c31\u8d4a\u7740\u2014\u2014\u53cd\u6b63\u90fd\u662f\u90bb\u5c45\uff0c\u8dd1\u4e0d\u4e86\u3002",
          "branch": "main"
        },
        {
          "text": "\u8ddf\u7740\u6da8\uff0c\u4e0d\u7136\u6491\u4e0d\u4f4f",
          "outcome": "\u6da8\u4e86\u4e24\u6587\u94b1\u3002\u6709\u4eba\u9a82\u4f60\u9ed1\u5fc3\u3002\u4f60\u6ca1\u5431\u58f0\u3002\u665a\u4e0a\u7b97\u8d26\uff1a\u4e0d\u6da8\u8fd9\u4e24\u6587\uff0c\u4e0b\u4e2a\u6708\u9762\u7c89\u90fd\u4e70\u4e0d\u8d77\u3002",
          "branch": "main"
        }
      ]
    },
    {
      "age": 45,
      "text": "\u81f3\u6b63\u4e8c\u5341\u516b\u5e74\u3002\u6731\u5143\u748b\u7684\u5175\u5230\u4e86\u57ce\u5916\u3002\u8499\u53e4\u7687\u5e1d\u534a\u591c\u5f00\u5317\u95e8\u8dd1\u4e86\u3002\u7b2c\u4e8c\u5929\u4f60\u5f00\u95e8\uff0c\u8857\u4e0a\u7a7a\u4e86\u4e00\u534a\u3002\u5927\u5143\u671d\u2014\u2014\u5b8c\u4e86\u3002\u4f60\u6d3b\u4e86\u56db\u5341\u4e94\u5e74\uff0c\u7ecf\u5386\u4e86\u4e00\u4e2a\u738b\u671d\u4ece\u76db\u5230\u4ea1\u3002\u4e09\u4e2a\u5b69\u5b50\uff1a\u8001\u5927\u5f53\u4e86\u8d27\u90ce\uff0c\u8001\u4e8c\u5ac1\u4e86\u4eba\uff0c\u8001\u4e09\u5b66\u4e86\u6ce5\u74e6\u5320\u3002\u90fd\u6d3b\u7740\u3002",
      "choices": null
    },
    {
      "age": 50,
      "text": "\u65b0\u671d\u6765\u4e86\u3002\u5927\u660e\u3002\u5927\u90fd\u6539\u540d\u53eb\u5317\u5e73\u3002\u4f60\u7684\u94fa\u5b50\u8fd8\u5f00\u7740\u2014\u2014\u9992\u5934\u3001\u7f8a\u6742\u6c64\u3001\u8c46\u9762\u997c\u3002\u65b0\u671d\u7684\u5175\u4e5f\u5f97\u5403\u996d\u3002\u4f60\u4e0d\u7ba1\u8c01\u5750\u5929\u4e0b\uff0c\u53ea\u7ba1\u9505\u91cc\u6709\u4e1c\u897f\u3002\u4e94\u5341\u5c81\u4e86\uff0c\u8170\u5f2f\u4e86\uff0c\u624b\u4e0a\u5168\u662f\u70eb\u7624\u3002\u4f46\u94fa\u5b50\u6ca1\u5173\u8fc7\u4e00\u5929\u95e8\u3002",
      "choices": null
    }
  ],
  "summary": "\u4f60\u662f\u5143\u671d\u5927\u90fd\u4e00\u4e2a\u6c49\u65cf\u5be1\u5987\uff0c\u56db\u7b49\u4eba\u91cc\u4e0d\u8d77\u773c\u7684\u7b2c\u4e09\u7b49\u3002\u4e08\u592b\u6b7b\u540e\u4f60\u63a5\u8fc7\u4e00\u9505\u7f8a\u6742\u6c64\uff0c\u628a\u4e09\u4e2a\u5b69\u5b50\u62c9\u626f\u5927\u4e86\u3002\u7269\u4ef7\u98de\u6da8\u3001\u5929\u4e0b\u5927\u4e71\u3001\u8499\u53e4\u4eba\u8dd1\u4e86\u3001\u65b0\u671d\u6765\u4e86\u2014\u2014\u4f60\u54ea\u671d\u90fd\u6ca1\u7ad9\u8fc7\uff0c\u53ea\u7ad9\u9505\u53f0\u8fb9\u3002\u4e94\u5341\u5c81\u4e86\u94fa\u5b50\u8fd8\u5f00\u7740\u3002\u8c01\u5750\u5929\u4e0b\u90fd\u5f97\u5403\u996d\u3002",
  "historyNote": "\u5143\u671d\u56db\u7b49\u4eba\u5236\u5ea6\uff1a\u8499\u53e4\u4eba\u4e00\u7b49\uff0c\u8272\u76ee\u4eba\u4e8c\u7b49\uff0c\u6c49\u4eba\uff08\u5317\u65b9\u6c49\u65cf\u53ca\u5973\u771f\u5951\u4e39\uff09\u4e09\u7b49\uff0c\u5357\u4eba\u56db\u7b49\u3002\u53f8\u6cd5\u4e0a\u6c49\u4eba\u6740\u8499\u53e4\u4eba\u507f\u547d\uff0c\u53cd\u4e4b\u4ec5\u7f5a\u94f6\u3002\u5143\u672b\u81f3\u6b63\u5e74\u95f4\u9ec4\u6cb3\u6cdb\u6ee5\u3001\u7ea2\u5dfe\u519b\u8d77\u4e49\uff0c\u5927\u90fd\u7269\u4ef7\u98de\u6da8\u30021368\u5e74\u516b\u6708\u660e\u519b\u5175\u4e34\u57ce\u4e0b\uff0c\u5143\u987a\u5e1d\u7531\u5efa\u5fb7\u95e8\u5317\u9003\u3002\u5927\u90fd\u6539\u540d\u5317\u5e73\u3002\u5143\u4ee3\u5927\u90fd\u996e\u98df\u4ee5\u7f8a\u8089\u4e3a\u4e3b\uff0c\u6c49\u4eba\u98df\u94fa\u82e5\u60f3\u505a\u8499\u53e4\u4eba\u3001\u8272\u76ee\u4eba\u751f\u610f\u9700\u9075\u5b88\u6e05\u771f\u89c4\u77e9\u3002"
}
