[
  {
    "id": "ottoman-kaya-01",
    "name": "\u6cd5\u8482\u739b",
    "era": "\u5965\u65af\u66fc\u5e1d\u56fd\u00b7\u82cf\u83b1\u66fc\u5927\u5e1d\u65f6\u671f\uff08\u7ea61550\u5e74\uff09",
    "location": "\u4f0a\u65af\u5766\u5e03\u5c14\u00b7\u6258\u666e\u5361\u5e15\u5bab",
    "oneLiner": "\u5207\u5c14\u514b\u65af\u5c11\u5973\u88ab\u63a0\u5165\u540e\u5bab\uff0c\u4e09\u5341\u5e74\u540e\u7ba1\u7740\u4e09\u767e\u53f7\u4eba\u7684\u5403\u559d\u62c9\u6492\u3002",
    "rarity": "rare",
    "tone": "blaze",
    "tags": ["\u5965\u65af\u66fc", "\u5973\u6027", "\u5bab\u5ef7", "\u4e2d\u95f4\u9636\u5c42", "16\u4e16\u7eaa"],
    "events": [
      {
        "age": 0,
        "text": "\u4f60\u51fa\u751f\u5728\u9ad8\u52a0\u7d22\u5c71\u811a\u4e0b\u7684\u5207\u5c14\u514b\u65af\u6751\u5e84\u3002\u7236\u4eb2\u517b\u9a6c\uff0c\u6bcd\u4eb2\u7ec7\u6bef\u3002\u4f60\u8bb0\u5f97\u9662\u5b50\u91cc\u6709\u4e00\u68f5\u6838\u6843\u6811\uff0c\u6bcf\u5e74\u79cb\u5929\u4f60\u8d1f\u8d23\u6361\u679c\u5b50\u3002\u4f60\u6709\u4e24\u4e2a\u54e5\u54e5\uff0c\u90fd\u6bd4\u4f60\u9ad8\u4e00\u5934\u3002",
        "choices": null
      },
      {
        "age": 10,
        "text": "\u514b\u91cc\u7c73\u4e9a\u7684\u5974\u96b6\u8d29\u5b50\u6765\u4e86\u3002\u4f60\u7236\u4eb2\u4e0d\u5728\u2014\u2014\u5728\u5c71\u90a3\u8fb9\u7ed9\u9a6c\u770b\u75c5\u3002\u4ed6\u4eec\u6311\u4e86\u4f60\u548c\u90bb\u5c45\u5bb6\u4e24\u4e2a\u5973\u5b69\u3002\u4f60\u54e5\u54e5\u8bd5\u56fe\u62e6\uff0c\u88ab\u6253\u7ffb\u5728\u5730\u3002\u4f60\u88ab\u585e\u4e0a\u9a6c\u8f66\u65f6\u56de\u5934\u770b\u4e86\u4e00\u773c\u6838\u6843\u6811\u3002\u4f60\u518d\u4e5f\u6ca1\u89c1\u8fc7\u90a3\u68f5\u6811\u3002",
        "choices": null
      },
      {
        "age": 12,
        "text": "\u4f60\u5230\u4e86\u4f0a\u65af\u5766\u5e03\u5c14\u7684\u5974\u96b6\u5e02\u573a\uff0c\u88ab\u5bab\u5ef7\u91c7\u8d2d\u5b98\u6311\u4e2d\u2014\u2014\u7259\u9f7f\u6574\u9f50\u3001\u773c\u775b\u4eae\u3002\u8fdb\u4e86\u6258\u666e\u5361\u5e15\u5bab\u540e\u5bab\uff0c\u5206\u5230\u6d17\u8863\u623f\u3002\u89c4\u77e9\u6bd4\u4f60\u4eec\u6751\u7684\u519b\u4e8b\u8bad\u7ec3\u8fd8\u4e25\uff1a\u8d70\u8def\u4e0d\u51fa\u58f0\uff0c\u8bf4\u8bdd\u7528\u656c\u8bed\uff0c\u72af\u9519\u4e0d\u80fd\u54ed\u3002\u4f46\u6709\u996d\u5403\u3001\u80fd\u5b66\u4e1c\u897f\u3002\u4f60\u5b66\u5f97\u5f88\u5feb\u3002",
        "choices": null
      },
      {
        "age": 18,
        "text": "\u4f60\u4ece\u6d17\u8863\u623f\u8c03\u5230\u4e86\u53a8\u623f\u7ba1\u4e8b\u624b\u4e0b\u3002\u4f60\u6709\u4e00\u6837\u672c\u4e8b\uff1a\u8fc7\u76ee\u4e0d\u5fd8\u3002\u8c01\u6b20\u8c01\u591a\u5c11\u9762\u7c89\u3001\u54ea\u4e2a\u6708\u9999\u6599\u7528\u8d85\u4e86\uff0c\u4f60\u5168\u8bb0\u5f97\u4f4f\u3002\u7ba1\u4e8b\u79bb\u4e0d\u5f00\u4f60\u4e86\u3002\u4f60\u7684\u7b49\u7ea7\u4ece\u300c\u666e\u901a\u5bab\u5973\u300d\u5347\u5230\u4e86\u300c\u6709\u540d\u5b57\u7684\u4eba\u300d\u3002\u540e\u5bab\u91cc\u5f00\u59cb\u6709\u4eba\u6253\u542c\uff1a\u90a3\u4e2a\u5207\u5c14\u514b\u65af\u6765\u7684\u53eb\u4ec0\u4e48\uff1f",
        "choices": null
      },
      {
        "age": 25,
        "text": "\u4f60\u505a\u5230\u4e86\u526f\u5361\u4e9a\u2014\u2014\u52a9\u7406\u5973\u603b\u7ba1\u3002\u7ba1\u4e00\u767e\u4e8c\u5341\u4e2a\u5bab\u5973\u7684\u5403\u7a7f\u4f4f\u884c\u3002\u540e\u5bab\u662f\u4e2a\u5c0f\u671d\u5ef7\uff1a\u8bb8\u857e\u59c6\u82cf\u4e39\uff08\u82cf\u83b1\u66fc\u7684\u5ba0\u5983\uff09\u548c\u9a6c\u5e0c\u5fb7\u82ac\u5170\u82cf\u4e39\uff08\u5927\u7687\u5b50\u4e4b\u6bcd\uff09\u5728\u4e89\u3002\u4f60\u5fc5\u987b\u7ad9\u961f\u3002",
        "choices": [
          {
            "text": "\u7ad9\u8bb8\u857e\u59c6\u2014\u2014\u5979\u52bf\u5934\u66f4\u731b",
            "outcome": "\u4f60\u628a\u540e\u5bab\u8d26\u76ee\u548c\u4eba\u4e8b\u90fd\u6309\u8bb8\u857e\u59c6\u7684\u610f\u601d\u529e\u3002\u5979\u5f88\u6ee1\u610f\u3002\u4f60\u8d4c\u7684\u662f\u5979\u80fd\u8d62\u2014\u2014\u5982\u679c\u5979\u8f93\u4e86\uff0c\u4f60\u5c31\u5b8c\u4e86\u3002",
            "branch": "main"
          },
          {
            "text": "\u7ad9\u9a6c\u5e0c\u5fb7\u82ac\u5170\u2014\u2014\u5979\u662f\u6b63\u7edf",
            "outcome": "\u5927\u7687\u5b50\u7a46\u65af\u5854\u6cd5\u662f\u957f\u5b50\uff0c\u6309\u7406\u8be5\u7ee7\u4f4d\u3002\u4f60\u62bc\u4ed6\u6bcd\u4eb2\u8fd9\u8fb9\u3002\u9a6c\u5e0c\u5fb7\u82ac\u5170\u7ed9\u4e86\u4f60\u4e00\u6279\u5fc3\u8179\u5bab\u5973\u7684\u540d\u5355\uff1a\u8fd9\u4e9b\u4eba\u8981\u5b89\u6392\u5230\u5173\u952e\u4f4d\u7f6e\u3002\u4f60\u7167\u529e\u4e86\u3002",
            "branch": 7
          },
          {
            "text": "\u4e24\u8fb9\u90fd\u4e0d\u7ad9\uff0c\u53ea\u505a\u4e8b",
            "outcome": "\u4f60\u8c01\u7684\u5fd9\u90fd\u5e2e\uff0c\u8c01\u90fd\u4e0d\u5f97\u7f6a\u3002\u4f46\u4f60\u5f88\u5feb\u53d1\u73b0\uff1a\u4e0d\u7ad9\u961f\u672c\u8eab\u5c31\u662f\u7ad9\u961f\u2014\u2014\u4e24\u8fb9\u90fd\u4e0d\u4fe1\u4efb\u4f60\u4e86\u3002\u5904\u5883\u8d8a\u6765\u8d8a\u5c2c\u5c2c\u3002\u4f60\u53ea\u80fd\u62fc\u547d\u628a\u4e8b\u505a\u597d\uff0c\u8ba9\u81ea\u5df1\u300c\u6709\u7528\u300d\u5230\u8c01\u90fd\u4e0d\u6562\u52a8\u4f60\u3002",
            "branch": "main"
          }
        ]
      },
      {
        "age": 38,
        "text": "\u8bb8\u857e\u59c6\u8d62\u4e86\u3002\u7a46\u65af\u5854\u6cd5\u88ab\u8d50\u6b7b\uff0c\u9a6c\u5e0c\u5fb7\u82ac\u5170\u88ab\u653e\u9010\u3002\u4f60\u6210\u4e86\u6b63\u5f0f\u7684\u5361\u4e9a\u2014\u2014\u540e\u5bab\u5973\u603b\u7ba1\u3002\u4e09\u767e\u591a\u53f7\u4eba\u5f52\u4f60\u7ba1\u3002\u4f60\u7b7e\u5b57\u624d\u80fd\u5f00\u5e93\u623f\uff0c\u82cf\u4e39\u5403\u7684\u6bcf\u9813\u996d\u540e\u9762\u90fd\u6709\u4f60\u7684\u624b\u3002\u4f60\u5341\u5c81\u88ab\u63a0\u6765\u65f6\u662f\u5974\u96b6\u3002\u4e09\u5341\u516b\u5c81\u7684\u4f60\u7ba1\u7684\u94b1\u6bd4\u5916\u9762\u4e00\u4e2a\u7701\u8fd8\u591a\u3002",
        "choices": null
      },
      {
        "age": 55,
        "text": "\u4f60\u5728\u8fd9\u4e2a\u4f4d\u5b50\u4e0a\u5750\u4e86\u5341\u4e03\u5e74\u3002\u4e09\u4e2a\u5ba0\u5983\u8d77\u843d\u3001\u4e24\u4f4d\u82cf\u4e39\u66f4\u66ff\u2014\u2014\u4f60\u90fd\u5728\u3002\u4e94\u5341\u4e94\u5c81\u4f60\u4e3b\u52a8\u8bf7\u9000\uff0c\u6309\u89c4\u77e9\u88ab\u8d50\u4e86\u517b\u8001\u91d1\u548c\u57ce\u91cc\u4e00\u6813\u5c0f\u623f\u5b50\u3002\u4f60\u8d70\u51fa\u5bab\u95e8\u90a3\u5929\u662f\u4e2a\u81ea\u7531\u4eba\u3002\u95e8\u5916\u9633\u5149\u523a\u773c\u3002\u4f60\u7ad9\u4e86\u4e00\u4f1a\u513f\u624d\u8fe8\u6b65\u3002",
        "choices": null
      },
      {
        "age": 0,
        "text": "[\u5206\u652f] \u4f60\u8d4c\u9519\u4e86\u3002\u7a46\u65af\u5854\u6cd5\u88ab\u82cf\u83b1\u66fc\u8d50\u6b7b\u7684\u90a3\u5929\uff0c\u4ed6\u6bcd\u4eb2\u4e00\u6d3e\u6240\u6709\u4eba\u88ab\u6e05\u6d17\u3002\u4f60\u88ab\u641c\u51fa\u4e86\u9a6c\u5e0c\u5fb7\u82ac\u5170\u7684\u4fe1\u2014\u2014\u8bc1\u636e\u786e\u51ff\u3002\u4f60\u6ca1\u88ab\u6740\uff0c\u4f46\u88ab\u5173\u8fdb\u4e86\u540e\u5bab\u6700\u6df1\u5904\u4e00\u95f4\u5c0f\u5c4b\uff0c\u7a97\u6237\u671d\u5317\uff0c\u6c38\u8fdc\u6ca1\u6709\u592a\u9633\u3002\u4f60\u5728\u90a3\u95f4\u5c4b\u5b50\u91cc\u6d3b\u4e86\u5341\u4e00\u5e74\u3002\u6ca1\u4eba\u8ddf\u4f60\u8bf4\u8bdd\u3002\u4f60\u6570\u5899\u4e0a\u7684\u88c2\u7f1d\uff0c\u60f3\u8d77\u5c0f\u65f6\u5019\u6570\u7816\u7f1d\u3002\u6700\u540e\u4f60\u6b7b\u5728\u90a3\u91cc\u3002\u6ca1\u4eba\u8bb0\u5f97\u4f60\u7684\u540d\u5b57\u3002",
        "choices": null,
        "branchEnd": true,
        "branchSummary": "\u4f60\u5341\u5c81\u88ab\u63a0\u79bb\u5bb6\u4e61\uff0c\u5728\u540e\u5bab\u722c\u4e86\u5341\u4e94\u5e74\u722c\u5230\u526f\u5361\u4e9a\u3002\u7136\u540e\u4f60\u7ad9\u9519\u4e86\u961f\u3002\u7a46\u65af\u5854\u6cd5\u88ab\u8d10\u6b7b\u90a3\u5929\uff0c\u4f60\u7684\u524d\u9014\u4e5f\u6b7b\u4e86\u3002\u88ab\u5e7d\u7981\u5341\u4e00\u5e74\uff0c\u6b7b\u5728\u6ca1\u6709\u9633\u5149\u7684\u5c4b\u5b50\u91cc\u3002\u6743\u529b\u8fd9\u4e1c\u897f\u2014\u2014\u722c\u4e0a\u53bb\u7528\u4e86\u5341\u4e94\u5e74\uff0c\u6454\u4e0b\u6765\u53ea\u8981\u4e00\u5929\u3002"
      }
    ],
    "summary": "\u4f60\u5341\u5c81\u88ab\u63a0\u79bb\u9ad8\u52a0\u7d22\u7684\u6751\u5e84\uff0c\u5728\u540e\u5bab\u4ece\u6d17\u8863\u623f\u722c\u5230\u4e86\u5973\u603b\u7ba1\u3002\u4f60\u4e0d\u6f02\u4eae\u4f46\u6709\u7528\u2014\u2014\u6709\u7528\u6bd4\u6f02\u4eae\u503c\u94b1\u3002\u4f60\u7ba1\u4e86\u4e09\u767e\u53f7\u4eba\u5341\u4e03\u5e74\uff0c\u89c1\u8fc7\u5ba0\u5983\u8d77\u843d\u3001\u82cf\u4e39\u66f4\u66ff\u3002\u4e94\u5341\u4e94\u5c81\u9000\u4f11\u8d70\u51fa\u5bab\u95e8\uff0c\u662f\u4e2a\u81ea\u7531\u4eba\u3002\u9633\u5149\u523a\u773c\uff0c\u4f60\u7ad9\u4e86\u4e00\u4f1a\u513f\u624d\u8fe8\u6b65\u3002",
    "historyNote": "\u5965\u65af\u66fc\u5e1d\u56fd\u540e\u5bab\u7531\u300c\u5361\u4e9a\u00b7\u5361\u767b\u300d\uff08\u5973\u603b\u7ba1\uff09\u7ba1\u7406\u3002\u5bab\u5973\u591a\u4e3a\u6218\u4ff8\u6216\u5974\u96b6\u5e02\u573a\u8d2d\u5165\u7684\u5207\u5c14\u514b\u65af\u3001\u683c\u9c81\u5409\u4e9a\u5c11\u5973\u3002\u82cf\u83b1\u66fc\u65f6\u671f\uff081520-1566\uff09\u8bb8\u857e\u59c6\u82cf\u4e39\u4e0e\u5927\u7687\u5b50\u7a46\u65af\u5854\u6cd5\u4e4b\u6bcd\u9a6c\u5e0c\u5fb7\u82ac\u5170\u7684\u6743\u529b\u6597\u4e89\u8d2f\u7a7f\u540e\u5bab\u30021553\u5e74\u7a46\u65af\u5854\u6cd5\u88ab\u8d50\u6b7b\uff0c\u5176\u6bcd\u88ab\u653e\u9010\u5e03\u5c14\u8428\u3002\u540e\u5bab\u7b49\u7ea7\u68ee\u4e25\uff0c\u5361\u4e9a\u638c\u7ba1\u6570\u767e\u4eba\u65e5\u5e38\u53ca\u5de8\u989d\u9884\u7b97\u3002\u5bab\u5973\u670d\u52a1\u6ee1\u671f\u53ef\u83b7\u91ca\u653e\u53ca\u5ac1\u5986\u3002"
  }
]
