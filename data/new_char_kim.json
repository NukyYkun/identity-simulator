{
  "id": "joseon-jungin-01",
  "name": "\u91d1\u5927\u6210",
  "era": "\u671d\u9c9c\u00b7\u82f1\u7956\u5e74\u95f4\uff08\u7ea61750\u5e74\uff09",
  "location": "\u6c49\u57ce\uff08\u4eca\u9996\u5c14\uff09",
  "oneLiner": "\u4e24\u73ed\u5bb6\u7684\u843d\u9b44\u5b50\u5f1f\uff0c\u8003\u4e0d\u4e0a\u79d1\u4e3e\u6539\u884c\u505a\u4e86\u7ffb\u8bd1\u5b98\uff0c\u53bb\u8fc7\u5317\u4eac\u4e09\u6b21\u540e\u6d3b\u660e\u767d\u4e86\u3002",
  "rarity": "common",
  "tone": "still",
  "tags": ["\u671d\u9c9c", "\u7537\u6027", "\u4e2d\u95f4\u9636\u5c42", "\u7ffb\u8bd1", "18\u4e16\u7eaa"],
  "events": [
    {
      "age": 0,
      "text": "\u4f60\u51fa\u751f\u5728\u6c49\u57ce\u5317\u6751\u3002\u7956\u4e0a\u662f\u4e24\u73ed\u8d35\u65cf\uff0c\u5230\u4f60\u7237\u7237\u8f88\u8fd8\u6709\u5b98\u505a\uff0c\u5230\u4f60\u7236\u4eb2\u2014\u2014\u7a77\u5f97\u53ea\u5269\u4e2a\u300c\u4e24\u73ed\u300d\u7684\u58f3\u4e86\u3002\u597d\u5728\u8eab\u4efd\u8fd8\u5728\uff1a\u4f60\u80fd\u8bfb\u4e66\u3001\u8003\u79d1\u4e3e\u3002\u7236\u4eb2\u4ece\u4f60\u4e09\u5c81\u8d77\u6559\u4f60\u80cc\u300a\u5343\u5b57\u6587\u300b\u3002\u4ed6\u8bf4\uff1a\u54b1\u5bb6\u7ffb\u8eab\u770b\u4f60\u4e86\u3002",
      "choices": null
    },
    {
      "age": 24,
      "text": "\u79d1\u4e3e\u8003\u4e86\u4e09\u6b21\uff0c\u5168\u843d\u4e86\u3002\u4f60\u4eca\u5e74\u4e8c\u5341\u56db\u3002\u7236\u4eb2\u5f00\u59cb\u54b3\u8840\uff0c\u5bb6\u91cc\u8fde\u53c2\u90fd\u4e70\u4e0d\u8d77\u3002\u4f60\u4e0d\u662f\u4e0d\u52aa\u529b\u2014\u2014\u4f60\u5c31\u662f\u4e0d\u884c\u3002\u6216\u8005\u8bf4\u8fd9\u6761\u8def\u592a\u6324\u4e86\uff1a\u4e24\u73ed\u5b50\u5f1f\u8d8a\u6765\u8d8a\u591a\uff0c\u540d\u989d\u5c31\u90a3\u4e48\u70b9\u3002",
      "choices": [
        {
          "text": "\u518d\u8bd5\u4e00\u6b21",
          "outcome": "\u7b2c\u56db\u6b21\u3002\u8fd8\u662f\u843d\u4e86\u3002\u4f46\u4f60\u4e0d\u540e\u6094\u2014\u2014\u4f60\u9700\u8981\u786e\u8ba4\u81ea\u5df1\u771f\u7684\u8d70\u4e0d\u901a\u8fd9\u6761\u8def\uff0c\u624d\u80fd\u6b7b\u5fc3\u3002",
          "branch": "main"
        },
        {
          "text": "\u5b66\u95e8\u5b9e\u7528\u7684\u2014\u2014\u4e2d\u56fd\u8bdd",
          "outcome": "\u53f8\u8bd1\u9662\u6536\u5b66\u751f\u3002\u4e24\u73ed\u5b50\u5f1f\u53bb\u5f53\u7ffb\u8bd1\u5b98\u4f1a\u88ab\u77a7\u4e0d\u8d77\u2014\u2014\u90a3\u662f\u4e2d\u4eba\u7684\u6d3b\u3002\u4f46\u4f60\u7a77\u5230\u6ca1\u8d44\u683c\u8981\u9762\u5b50\u4e86\u3002\u4f60\u53bb\u4e86\u3002",
          "branch": "main"
        }
      ]
    },
    {
      "age": 26,
      "text": "\u4f60\u6210\u4e86\u53f8\u8bd1\u9662\u8bd1\u5b98\u3002\u4e2d\u4eba\u9636\u5c42\u2014\u2014\u4e0d\u4e0a\u4e0d\u4e0b\u3002\u4e24\u73ed\u540c\u7a97\u80cc\u540e\u8bae\u8bba\u4f60\u3002\u4f46\u4e2d\u4eba\u6709\u94b1\u8d5a\uff1a\u8ddf\u671d\u8d21\u4f7f\u56e2\u53bb\u5317\u4eac\uff0c\u8def\u4e0a\u80fd\u505a\u8d38\u6613\u3002\u4f60\u7b2c\u4e00\u6b21\u4ee5\u8bd1\u5b98\u8eab\u4efd\u51fa\u53d1\u65f6\u4e8c\u5341\u516d\u5c81\u3002\u79bb\u5f00\u6c49\u57ce\u90a3\u5929\u65e9\u4e0a\u4f60\u56de\u5934\u770b\u4e86\u4e00\u773c\u3002\u6ca1\u4ec0\u4e48\u53ef\u7559\u604b\u7684\u3002",
      "choices": null
    },
    {
      "age": 28,
      "text": "\u7b2c\u4e00\u6b21\u5230\u5317\u4eac\u3002\u4f60\u9707\u4e86\u3002\u7409\u7483\u5382\u4e66\u8086\u91cc\u6709\u8bfb\u4e0d\u5b8c\u7684\u4e66\uff0c\u524d\u95e8\u5927\u8857\u4e0a\u6709\u6ca1\u89c1\u8fc7\u7684\u4e1c\u897f\u2014\u2014\u897f\u6d0b\u949f\u8868\u3001\u73bb\u7483\u5668\u3001\u9f3b\u70df\u58f6\u3002\u6e05\u671d\u6587\u4eba\u5c45\u7136\u613f\u610f\u8ddf\u4f60\u804a\u5929\u2014\u2014\u4ed6\u4eec\u4e0d\u95ee\u4f60\u5728\u671d\u9c9c\u4ec0\u4e48\u9636\u5c42\u3002\u5728\u8fd9\u91cc\u4f60\u53ea\u662f\u300c\u671d\u9c9c\u6765\u7684\u8bfb\u4e66\u4eba\u300d\u3002\u6d3b\u4e86\u4e8c\u5341\u516b\u5e74\uff0c\u7b2c\u4e00\u6b21\u89c9\u5f97\u8eab\u4efd\u4e0d\u662f\u67b7\u9501\u3002",
      "choices": [
        {
          "text": "\u7591\u72c2\u4e70\u4e66\u5e26\u56de\u53bb",
          "outcome": "\u8d38\u6613\u8d5a\u7684\u94b1\u5168\u7838\u5728\u7409\u7483\u5382\u4e86\u3002\u4e09\u7bb1\u4e66\u3002\u56de\u6c49\u57ce\u540e\u4f60\u6210\u4e86\u90a3\u5e2e\u4e24\u73ed\u4e66\u751f\u90fd\u7fa1\u6155\u7684\u4eba\u2014\u2014\u4f60\u6709\u6700\u65b0\u7684\u4e2d\u56fd\u4e66\u3002\u4ed6\u4eec\u60f3\u501f\uff1f\u53ef\u4ee5\u3002\u4f60\u7ec8\u4e8e\u6709\u4e86\u4ed6\u4eec\u60f3\u8981\u7684\u4e1c\u897f\u3002",
          "branch": "main"
        },
        {
          "text": "\u7ed3\u4ea4\u5317\u4eac\u6587\u4eba",
          "outcome": "\u4f60\u8ba4\u8bc6\u4e86\u51e0\u4e2a\u6c49\u65cf\u6587\u4eba\uff0c\u901b\u4e86\u7409\u7483\u5382\u3001\u53bb\u4e86\u4eac\u90ca\u6e29\u6cc9\u3002\u7528\u78d5\u5df4\u7684\u5317\u4eac\u8bdd\u804a\u8bd7\u804a\u5929\u4e0b\u3002\u56de\u6765\u540e\u4f60\u7684\u4e2d\u56fd\u8bdd\u7a81\u7136\u6d41\u5229\u4e86\u2014\u2014\u4e0d\u662f\u5b66\u51fa\u6765\u7684\uff0c\u662f\u804a\u51fa\u6765\u7684\u3002",
          "branch": "main"
        }
      ]
    },
    {
      "age": 40,
      "text": "\u53bb\u8fc7\u4e09\u6b21\u5317\u4eac\u4e86\u3002\u6bcf\u6b21\u56de\u6765\u90fd\u89c9\u5f97\u6c49\u57ce\u5c0f\u4e86\u4e00\u70b9\u3002\u65e5\u5b50\u7a33\u4e86\uff1a\u7ffb\u8bd1\u6d3b\u7a33\u5b9a\uff0c\u8d38\u6613\u5c0f\u8d5a\uff0c\u4e0d\u5bcc\u4f46\u4e0d\u7a77\u3002\u513f\u5b50\u95ee\uff1a\u963f\u7239\u6211\u5c06\u6765\u4e5f\u8003\u79d1\u4e3e\u5417\uff1f",
      "choices": [
        {
          "text": "\u300c\u4f60\u8bd5\u8bd5\uff0c\u4e07\u4e00\u6bd4\u4f60\u7239\u806a\u660e\u300d",
          "outcome": "\u4ed6\u540e\u6765\u4e5f\u843d\u4e86\u699c\u3002\u4f46\u4ed6\u6ca1\u4f60\u5f53\u5e74\u90a3\u4e48\u75db\u2014\u2014\u4f60\u65e9\u544a\u8bc9\u4ed6\u4e86\uff1a\u843d\u4e86\u4e5f\u6ca1\u4e8b\uff0c\u8def\u4e0d\u6b62\u4e00\u6761\u3002",
          "branch": "main"
        },
        {
          "text": "\u300c\u5b66\u95e8\u624b\u827a\uff0c\u6d3b\u7740\u6700\u8981\u7d27\u300d",
          "outcome": "\u4f60\u6559\u513f\u5b50\u4e2d\u56fd\u8bdd\u3002\u706f\u4e0b\u7236\u5b50\u2014\u2014\u8ddf\u4f60\u7239\u6559\u4f60\u80cc\u4e66\u7684\u573a\u666f\u4e00\u6837\uff0c\u53ea\u662f\u6559\u7684\u4e1c\u897f\u4e0d\u4e00\u6837\u4e86\u3002",
          "branch": "main"
        }
      ]
    },
    {
      "age": 58,
      "text": "\u4e94\u5341\u516b\u5c81\u3002\u9000\u4e86\u804c\uff0c\u5728\u5bb6\u8bfb\u4e66\u5199\u5b57\uff0c\u5076\u5c14\u6559\u90bb\u5c45\u5b69\u5b50\u4e2d\u56fd\u8bdd\u3002\u6ca1\u5f53\u8fc7\u5927\u5b98\u6ca1\u53d1\u8fc7\u5927\u8d22\uff0c\u4e5f\u6ca1\u997f\u8fc7\u809a\u5b50\u3002\u53bb\u8fc7\u4e09\u6b21\u5317\u4eac\u3001\u8bfb\u4e86\u4e00\u8f88\u5b50\u4e66\u3002\u4f60\u6d3b\u660e\u767d\u4e86\u4e00\u4ef6\u4e8b\uff1a\u4eba\u6700\u6015\u7684\u4e0d\u662f\u547d\u4e0d\u597d\uff0c\u662f\u62e7\u7740\u547d\u8d70\u3002\u5e74\u8f7b\u65f6\u62e7\u4e86\u5341\u5e74\uff0c\u540e\u6765\u987a\u4e86\uff0c\u5c31\u901a\u4e86\u3002\u665a\u4e0a\u4e00\u676f\u6d4a\u9152\u770b\u6708\u4eae\u3002\u633a\u597d\u3002",
      "choices": null
    }
  ],
  "summary": "\u4e24\u73ed\u5bb6\u7684\u843d\u9b44\u5b50\u5f1f\uff0c\u79d1\u4e3e\u56db\u6b21\u5168\u843d\u3002\u6539\u884c\u505a\u4e86\u7ffb\u8bd1\u5b98\u2014\u2014\u4e2d\u4eba\u9636\u5c42\uff0c\u4e0d\u4e0a\u4e0d\u4e0b\u3002\u8ddf\u4f7f\u56e2\u53bb\u4e86\u4e09\u6b21\u5317\u4eac\uff0c\u5728\u90a3\u91cc\u6ca1\u4eba\u5728\u4e4e\u4f60\u662f\u4ec0\u4e48\u7b49\u7ea7\u3002\u4e94\u5341\u516b\u5c81\u9000\u804c\u3002\u4f60\u8fd9\u8f88\u5b50\u6ca1\u6709\u5927\u8d77\u5927\u843d\uff0c\u4f46\u4f60\u6d3b\u660e\u767d\u4e86\uff1a\u4eba\u6700\u6015\u7684\u4e0d\u662f\u547d\u4e0d\u597d\uff0c\u662f\u62e7\u7740\u547d\u8d70\u3002",
  "historyNote": "\u671d\u9c9c\u738b\u671d\u793e\u4f1a\u9636\u5c42\u56fa\u5316\uff1a\u4e24\u73ed\u3001\u4e2d\u4eba\u3001\u5e38\u6c11\u3001\u8d31\u6c11\u3002\u79d1\u4e3e\u53ea\u5bf9\u4e24\u73ed\u5f00\u653e\u4f46\u540d\u989d\u6709\u9650\uff0c\u5927\u91cf\u4e24\u73ed\u5b50\u5f1f\u7ec8\u8eab\u843d\u699c\u3002\u53f8\u8bd1\u9662\u8d1f\u8d23\u5916\u4ea4\u7ffb\u8bd1\uff0c\u8bd1\u5b98\u968f\u671d\u8d21\u4f7f\u56e2\u8d74\u4eac\u53ef\u505a\u4eba\u53c2\u3001\u4e66\u7c4d\u8d38\u6613\u3002\u82f1\u7956\u5e74\u95f4\uff081724-1776\uff09\u4e2d\u4eba\u901a\u8fc7\u7ecf\u6d4e\u5b9e\u529b\u6e10\u83b7\u6587\u5316\u8bdd\u8bed\u6743\uff0c\u51fa\u73b0\u4e2d\u4eba\u6587\u4eba\u7fa4\u4f53\uff08\u300c\u59d4\u5df7\u6587\u5b66\u300d\uff09\u3002"
}
